{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "typeui": {
      "type": "remote",
      "url": "https://mcp.typeui.sh",
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-53e57b55-489d-44cb-b533-78009b76b3c5"
      },
      "enabled": true
    },
    "fonttrio": {
      "type": "remote",
      "url": "https://www.fonttrio.xyz/api/mcp",
      "enabled": true
    }
  },
  "plugin": ["./.opencode/plugins/ponytail.mjs"]
}
